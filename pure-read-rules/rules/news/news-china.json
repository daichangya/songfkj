{
  "meta": {
    "name": "中国网新闻",
    "description": "中国网新闻正文提取规则（参考 SimpRead）",
    "author": "Pure Read Team",
    "version": "1.0.0",
    "category": "news",
    "updatedAt": "2026-02-25"
  },
  "rule": {
    "host": "news.china",
    "pathPattern": "/",
    "titleSelector": "h1.articleTitle",
    "contentSelector": "div#articleBody",
    "excludeSelectors": [
      "[id*='recommend']",
      "[class*='related']",
      "[class*='hot-news']",
      "[class*='redian']",
      "[class*='channel-hot']",
      "[class*='remen']",
      "[class*='guanggao']",
      "[class*='tuijian']",
      "[class*='paihang']",
      "[class*='xiangguang']",
      "[id*='CH_MTL']",
      "[class*='med_area']",
      "[class*='media-fixed']",
      "#js-media-fixed"
    ]
  }
}
